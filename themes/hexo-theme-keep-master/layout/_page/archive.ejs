<div class="fade-in-down-animation">
    <div class="archives-container">
        <div class="archives-layout border-box">
            <aside class="archives-tags border-box">
                <div class="archives-section-title"><i class="fa-solid fa-tags"></i><span><%= __('tag') %></span></div>
                <% if (site.tags.length){ %>
                    <div class="tagcloud-content">
                        <%- tagcloud({
                            min_font: 1,
                            max_font: 1,
                            unit: 'rem',
                            amount: 100
                        }) %>
                    </div>
                <% } else { %>
                    <%- partial('_partial/common/empty-content') %>
                <% } %>
            </aside>
            <div class="archives-main border-box">
                <div class="archives-section-title"><i class="fa-solid fa-box-archive"></i><span><%= __('archive') %></span></div>
                <div class="archives-timeline border-box">
                    <%- partial('_partial/archive-list', { archive_posts: page.posts }) %>
                </div>
            </div>
        </div>
    </div>
    <%- partial('_partial/paginator', { page_info: page }) %>
</div>
