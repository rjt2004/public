.archives-container {
  keep-container(1, 2rem, 2rem)

  .archives-layout {
    display grid
    grid-template-columns minmax(0, 1fr) 16rem
    gap 2rem
    align-items start
  }

  .archives-section-title {
    display flex
    gap 0.55rem
    align-items center
    margin-bottom 1.2rem
    color var(--text-color-2)
    font-weight 600
    font-size 1.15rem

    i {
      color var(--primary-color)
      font-size 1rem
    }
  }

  .archives-main,
  .archives-tags {
    min-width 0
  }

  .archives-tags {
    position sticky
    top 5rem
    padding 1.2rem
    background var(--background-color-2)
    border-radius var(--box-border-radius)
  }

  .tagcloud-content {
    display flex
    flex-wrap wrap
    gap 0.6rem
    text-align left

    a {
      display inline-flex
      align-items center
      box-sizing border-box
      padding 0.38rem 0.62rem
      color var(--text-color-3)
      line-height 1.3
      background var(--background-color-1)
      border-radius 0.35rem

      &:hover {
        color var(--background-color-1)
        background var(--primary-color)
      }
    }
  }

  +keep-tablet() {
    .archives-layout {
      grid-template-columns 1fr
    }

    .archives-tags {
      position static
    }
  }

  +keep-mobile() {
    padding 1.2rem !important

    .archives-layout {
      gap 1.4rem
    }

    .archives-tags {
      padding 1rem
    }
  }
}
