.archives-container {
  width var(--page-content-max-width)
  max-width 100%
  margin 0 auto
  padding 2rem
  box-sizing border-box

  .archives-layout {
    display flex
    flex-direction column
    gap 2rem
  }

  .archives-section-title {
    display flex
    gap 0.55rem
    align-items center
    margin-bottom 1.2rem
    color var(--text-color-2)
    font-weight 600
    font-size 1.15rem

    i {
      color var(--primary-color)
      font-size 1rem
    }
  }

  .archives-main,
  .archives-tags {
    keep-container(1, 2rem, 0)
    min-width 0
  }

  .tagcloud-content {
    display flex
    flex-wrap wrap
    gap 0.6rem
    text-align left

    a {
      display inline-flex
      align-items center
      box-sizing border-box
      padding 0.38rem 0.62rem
      color var(--text-color-3)
      font-size 1rem !important
      line-height 1.3
      background var(--background-color-2)
      border-radius 0.35rem

      &:hover {
        color var(--background-color-1)
        background var(--primary-color)
      }
    }
  }

  +keep-mobile() {
    padding 1.2rem !important

    .archives-layout {
      gap 1.4rem
    }

    .archives-main,
    .archives-tags {
      padding 1.4rem
    }
  }
}
